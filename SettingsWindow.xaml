<Window x:Class="AnimalChess.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="520" Width="520"
        MinHeight="460" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#111827">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="Settings" Foreground="#F9FAFB" FontSize="26" FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText" Text="Language, theme and AI opponent options." Foreground="#9CA3AF" FontSize="13" Margin="0,4,0,18" />
        </StackPanel>

        <StackPanel Grid.Row="1" Background="#1F2937">
            <StackPanel Margin="18">
                <TextBlock x:Name="LanguageLabel" Text="Language" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="LanguageComboBox" Height="34" SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="English" Tag="en-US" />
                    <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                    <ComboBoxItem Content="繁體中文" Tag="zh-TW" />
                </ComboBox>

                <TextBlock x:Name="ThemeLabel" Text="Theme" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,18,0,6" />
                <ComboBox x:Name="ThemeComboBox" Height="34" />

                <TextBlock x:Name="GameModeLabel" Text="Game Mode" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,22,0,6" />
                <ComboBox x:Name="GameModeComboBox" Height="34" SelectionChanged="GameModeComboBox_SelectionChanged" />

                <TextBlock x:Name="AiDifficultyLabel" Text="AI Difficulty" Foreground="#F9FAFB" FontSize="15" FontWeight="SemiBold" Margin="0,18,0,6" />
                <ComboBox x:Name="AiDifficultyComboBox" Height="34" />

                <Border Background="#263241" CornerRadius="10" Padding="12" Margin="0,16,0,0">
                    <TextBlock x:Name="AiHintText" Text="Easy AI plays random legal moves. Medium AI scores captures, den pressure and safety." Foreground="#D1D5DB" FontSize="13" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Width="92" Height="34" Margin="0,0,10,0" Click="CancelButton_Click" />
            <Button x:Name="ApplyButton" Content="Apply" Width="92" Height="34" Click="ApplyButton_Click" />
        </StackPanel>
    </Grid>
</Window>
