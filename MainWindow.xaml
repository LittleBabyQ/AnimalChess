<Window x:Class="AnimalChess.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animal Chess" Height="820" Width="1080"
        MinHeight="680" MinWidth="920"
        Background="#111827">
    <Grid>
        <Grid x:Name="BackgroundLayer" Background="#111827">
            <Image x:Name="ThemeBackgroundImage" Stretch="UniformToFill" Opacity="0.95" Visibility="Collapsed" />
            <Rectangle Fill="#33111827" />
        </Grid>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,18">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Animal Chess" Foreground="#F9FAFB" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText" Text="Minimal Jungle Chess" Foreground="#D1D5DB" FontSize="15" Margin="2,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ThemeLabel" Text="Theme" Foreground="#D1D5DB" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ThemeComboBox" Width="142" Height="34" Margin="0,0,10,0" SelectionChanged="ThemeComboBox_SelectionChanged" />
                    <TextBlock x:Name="LanguageLabel" Text="Language" Foreground="#D1D5DB" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="LanguageComboBox" Width="122" Height="34" Margin="0,0,10,0" SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Content="English" Tag="en-US" />
                        <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                        <ComboBoxItem Content="繁體中文" Tag="zh-TW" />
                    </ComboBox>
                    <Button x:Name="SettingsButton" Content="Settings" Width="92" Height="34" Margin="0,0,10,0" Click="SettingsButton_Click" />
                    <Button x:Name="RulesButton" Content="Rules" Width="82" Height="34" Margin="0,0,10,0" Click="RulesButton_Click" />
                    <Button x:Name="UndoButton" Content="Undo" Width="92" Height="34" Margin="0,0,10,0" Click="UndoButton_Click" />
                    <Button x:Name="RestartButton" Content="Restart" Width="102" Height="34" Click="RestartButton_Click" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#661F2937" CornerRadius="18" Padding="18">
                    <UniformGrid x:Name="BoardGrid" Rows="9" Columns="7" />
                </Border>

                <Border Grid.Column="1" Background="#661F2937" CornerRadius="18" Padding="18" Margin="18,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatusTitle" Text="Status" Foreground="#F9FAFB" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="TurnText" Foreground="#D1D5DB" FontSize="16" Margin="0,14,0,0" TextWrapping="Wrap" />
                        <TextBlock x:Name="CapturedTitle" Text="Captured" Foreground="#F9FAFB" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,8" />
                        <TextBlock x:Name="CapturedText" Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" />
                        <TextBlock x:Name="RulesTitle" Text="Rules" Foreground="#F9FAFB" FontSize="18" FontWeight="SemiBold" Margin="0,30,0,8" />
                        <TextBlock x:Name="RulesSummaryText" Foreground="#D1D5DB" FontSize="13" TextWrapping="Wrap" LineHeight="20" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="BuildLabel" Grid.Row="2" Foreground="#D1D5DB" FontSize="12" Margin="2,14,0,0" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
