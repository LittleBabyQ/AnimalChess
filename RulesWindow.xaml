<Window x:Class="AnimalChess.RulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rules" Height="640" Width="680"
        MinHeight="520" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#111827">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" Text="Rules" Foreground="#F9FAFB" FontSize="26" FontWeight="SemiBold" />
            <TextBlock x:Name="SubtitleText" Text="Learn the board, pieces, terrain and winning conditions." Foreground="#9CA3AF" FontSize="13" Margin="0,4,0,18" />
        </StackPanel>

        <Border Grid.Row="1" Background="#CC1F2937" CornerRadius="14" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="RulesDetailText" Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" LineHeight="24" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="OpenWebsiteButton" Content="View Full Illustrated Rules" Width="190" Height="34" Margin="0,0,10,0" Click="OpenWebsiteButton_Click" />
            <Button x:Name="CloseButton" Content="Close" Width="92" Height="34" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
